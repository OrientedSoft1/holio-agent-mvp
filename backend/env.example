# =============================================================================
# Holio Agent Backend - Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=holio_agent

# Redis (for Bull queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d

# AWS (for SNS SMS)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Bedrock (separate credentials with bedrock:InvokeModel permission)
# Falls back to AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY if not set
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=
AWS_BEDROCK_REGION=us-east-1

# Knowledge Base Role ARN (IAM role for Bedrock KB to access S3/OpenSearch)
KB_ROLE_ARN=

# OpenSearch Serverless Collection ARN (for Bedrock Knowledge Base vector storage)
# Format: arn:aws:aoss:<region>:<account-id>:collection/<collection-id>
AOSS_COLLECTION_ARN=

# OpenSearch Serverless Vector Index Name (default: bedrock-kb-index)
AOSS_INDEX_NAME=bedrock-kb-index

# File Uploads
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/uploads

# GIPHY API (for GIF search - get key at developers.giphy.com)
GIPHY_API_KEY=

# Dev Override Phones (skip SMS in development, format: phone:pin,phone2:pin2)
DEV_OVERRIDE_PHONES=40040056:11111

# Bedrock Encryption Key (32 chars, for encrypting stored AWS credentials)
BEDROCK_ENCRYPTION_KEY=your-32-char-encryption-key-here

# OpenAI (optional, for OpenAI model support in AI Playground)
# Falls back to per-company stored API key if not set
OPENAI_API_KEY=

# Google Gemini (optional, for Gemini model support in AI Playground and Image Generation)
# Falls back to per-company stored API key if not set
GEMINI_API_KEY=

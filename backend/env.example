# ── Database ──────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=holio_agent

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRES_IN=15m

# ── SMS (AWS SNS) ────────────────────────────────────
# Set SMS_ENABLED=true to send real SMS via AWS SNS.
# When false, OTP codes are logged to the console.
SMS_ENABLED=false
AWS_SNS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Sender ID shown on the recipient's phone (max 11 alphanumeric chars).
# Not supported in all countries (e.g. US requires a phone number instead).
SMS_SENDER_ID=Holio

# ── AWS Bedrock ──────────────────────────────────────
AWS_BEDROCK_REGION=us-east-1

# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
